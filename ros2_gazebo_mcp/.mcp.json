{
  "mcpServers": {
    "gazebo": {
      "type": "stdio",
      "command": "/usr/bin/python3.10",
      "args": [
        "-m",
        "mcp.server.server"
      ],
      "env": {
        "PYTHONPATH": "${PWD}/src:${PWD}",
        "ROS_DOMAIN_ID": "0",
        "PATH": "/opt/ros/humble/bin:${PATH}",
        "LD_LIBRARY_PATH": "/opt/ros/humble/lib:${LD_LIBRARY_PATH:-}",
        "AMENT_PREFIX_PATH": "/opt/ros/humble"
      }
    }
  }
}
